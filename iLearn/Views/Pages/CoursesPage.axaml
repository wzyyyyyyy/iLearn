<UserControl
    x:Class="iLearn.Views.Pages.CoursesPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iLearn.ViewModels.Pages"
    x:DataType="vm:CoursesViewModel"
    x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <StackPanel Spacing="2">
          <TextBlock Text="课程工作台" Classes="section-title" />
          <TextBlock Text="{Binding StatusText}" Classes="muted" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <ComboBox Width="260" ItemsSource="{Binding TermsOptions}" SelectedItem="{Binding SelectedTerm}" />
          <Button Content="刷新" Classes="primary" Command="{Binding RefreshCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <ProgressBar Grid.Row="1" IsIndeterminate="True" IsVisible="{Binding IsBusy}" />

    <ScrollViewer Grid.Row="2">
      <ItemsControl ItemsSource="{Binding MyCourses}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <WrapPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Command="{Binding DataContext.CourseSelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    Width="318"
                    Height="214"
                    Margin="0,0,16,16"
                    Padding="0"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}">
              <Grid RowDefinitions="86,*,Auto">
                <Border Background="{StaticResource AccentSoftBrush}"
                        CornerRadius="8,8,0,0"
                        ClipToBounds="True">
                  <Grid ColumnDefinitions="Auto,*" Margin="16,0">
                    <Border Width="48"
                            Height="48"
                            CornerRadius="8"
                            Background="{StaticResource SurfaceBrush}"
                            VerticalAlignment="Center">
                      <Image Source="avares://iLearn/Assets/iLearn.png"
                             Width="34"
                             Height="34"
                             Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="12,0,0,0"
                                Spacing="2">
                      <TextBlock Text="课程"
                                 FontSize="12"
                                 Foreground="{StaticResource AccentBrush}" />
                      <TextBlock Text="{Binding StatusName}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{StaticResource AccentBrush}" />
                    </StackPanel>
                  </Grid>
                </Border>
                <StackPanel Grid.Row="1" Spacing="7" Margin="16,14,16,8">
                  <TextBlock Text="{Binding CourseName}"
                             FontSize="16"
                             FontWeight="SemiBold"
                             TextWrapping="Wrap"
                             MaxLines="2" />
                  <TextBlock Text="{Binding TeacherName}" Classes="muted" />
                </StackPanel>
                <Border Grid.Row="1"
                        Height="1"
                        Background="{StaticResource BorderBrushSoft}"
                        VerticalAlignment="Bottom" />
                <TextBlock Grid.Row="2"
                           Text="打开课程视频"
                           Classes="muted"
                           FontSize="12"
                           Margin="16,0,16,14" />
              </Grid>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </Grid>
</UserControl>
