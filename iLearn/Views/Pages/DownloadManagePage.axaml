<UserControl
    x:Class="iLearn.Views.Pages.DownloadManagePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iLearn.ViewModels.Pages"
    x:DataType="vm:DownloadManageViewModel"
    x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <StackPanel Spacing="2">
          <TextBlock Text="下载管理" Classes="section-title" />
          <TextBlock Text="{Binding TotalDownloadSpeed}" Classes="muted" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="重试失败" Command="{Binding RetryFailedCommand}" />
          <Button Content="清理完成" Command="{Binding ClearCompletedCommand}" />
          <Button Content="打开下载文件夹" Classes="primary" Command="{Binding OpenDownloadsFolderCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <UniformGrid Grid.Row="1" Columns="4" Rows="1">
      <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
        <TextBlock Text="{Binding ActiveDownloadsCount, StringFormat='下载中 {0}'}" FontWeight="SemiBold" />
      </Border>
      <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
        <TextBlock Text="{Binding QueuedDownloadsCount, StringFormat='排队 {0}'}" FontWeight="SemiBold" />
      </Border>
      <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
        <TextBlock Text="{Binding FailedDownloadsCount, StringFormat='失败 {0}'}" FontWeight="SemiBold" />
      </Border>
      <Border Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="14">
        <TextBlock Text="{Binding CompletedDownloadsCount, StringFormat='已完成 {0}'}" FontWeight="SemiBold" />
      </Border>
    </UniformGrid>

    <Border Grid.Row="2"
            IsVisible="{Binding HasNoDownloads}"
            Padding="28"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8">
      <StackPanel HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="还没有下载任务" Classes="section-title" />
        <TextBlock Text="在课程下载里选择 HDMI 或教师画面后，这里会显示进度。" Classes="muted" />
      </StackPanel>
    </Border>

    <ListBox Grid.Row="2" ItemsSource="{Binding Downloads}" IsVisible="{Binding HasDownloads}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrushSoft}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
            <StackPanel Spacing="7">
              <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
              <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" />
              <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource DangerBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Content="打开" Classes="quiet" Command="{Binding DataContext.OpenDownloadFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
            <Button Grid.Column="2" Content="暂停" Classes="quiet" Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
            <Button Grid.Column="3" Content="重试" Classes="quiet" Command="{Binding DataContext.RetryDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
            <Button Grid.Column="4" Content="取消" Classes="quiet" Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
          </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
