<UserControl
    x:Class="iLearn.Views.Pages.DownloadManagePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iLearn.ViewModels.Pages"
    x:DataType="vm:DownloadManageViewModel"
    x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="14">
    <DockPanel>
      <StackPanel>
        <TextBlock Text="下载管理" FontSize="30" FontWeight="SemiBold" />
        <TextBlock Text="{Binding TotalDownloadSpeed}" Foreground="#64748B" />
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8">
        <Button Content="重试失败" Command="{Binding RetryFailedCommand}" />
        <Button Content="清理完成" Command="{Binding ClearCompletedCommand}" />
        <Button Content="打开下载文件夹" Command="{Binding OpenDownloadsFolderCommand}" />
      </StackPanel>
    </DockPanel>

    <UniformGrid Grid.Row="1" Columns="4">
      <TextBlock Text="{Binding ActiveDownloadsCount, StringFormat='下载中 {0}'}" />
      <TextBlock Text="{Binding QueuedDownloadsCount, StringFormat='排队 {0}'}" />
      <TextBlock Text="{Binding FailedDownloadsCount, StringFormat='失败 {0}'}" />
      <TextBlock Text="{Binding CompletedDownloadsCount, StringFormat='已完成 {0}'}" />
    </UniformGrid>

    <Border Grid.Row="2"
            IsVisible="{Binding HasNoDownloads}"
            Padding="28"
            Background="#FFFFFF"
            BorderBrush="#E5E7EB"
            BorderThickness="1"
            CornerRadius="6">
      <StackPanel HorizontalAlignment="Center" Spacing="8">
        <TextBlock Text="还没有下载任务" FontSize="18" FontWeight="SemiBold" />
        <TextBlock Text="在课程下载里选择 HDMI 或教师画面后，这里会显示进度。" Foreground="#64748B" />
      </StackPanel>
    </Border>

    <ListBox Grid.Row="2" ItemsSource="{Binding Downloads}" IsVisible="{Binding HasDownloads}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="0,0,0,12">
            <StackPanel>
              <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" />
              <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progress}" />
              <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" />
            </StackPanel>
            <Button Grid.Column="1" Content="打开" Command="{Binding DataContext.OpenDownloadFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
            <Button Grid.Column="2" Content="暂停" Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
            <Button Grid.Column="3" Content="重试" Command="{Binding DataContext.RetryDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
            <Button Grid.Column="4" Content="取消" Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" />
          </Grid>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
