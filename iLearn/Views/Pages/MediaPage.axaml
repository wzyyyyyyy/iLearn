<UserControl
    x:Class="iLearn.Views.Pages.MediaPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iLearn.ViewModels.Pages"
    x:DataType="vm:MediaViewModel"
    x:CompileBindings="False">
  <Grid RowDefinitions="Auto,Auto,*" RowSpacing="16">
    <Border Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <StackPanel Spacing="2">
          <TextBlock Text="课程视频" Classes="section-title" />
          <TextBlock Text="{Binding CurrentCourse.CourseName}" Classes="muted" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <TextBox Width="300" Watermark="搜索视频或教师" Text="{Binding SearchQuery}" />
          <Button Content="刷新" Classes="primary" Command="{Binding RefreshCommand}" />
        </StackPanel>
      </Grid>
    </Border>

    <ProgressBar Grid.Row="1" IsIndeterminate="True" IsVisible="{Binding IsBusy}" />

    <ListBox Grid.Row="2" ItemsSource="{Binding MediaItems}">
      <ListBox.ItemTemplate>
        <DataTemplate>
          <Border Background="{StaticResource SurfaceBrush}"
                  BorderBrush="{StaticResource BorderBrushSoft}"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="14"
                  Margin="0,0,0,10">
          <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="{Binding LiveRecordName}" FontSize="16" FontWeight="SemiBold" />
              <TextBlock Text="{Binding TeacherName}" Classes="muted" />
              <TextBlock Text="{Binding TimeRange}" Classes="subtle" />
            </StackPanel>
            <Button Grid.Column="1"
                    Content="播放"
                    Classes="primary"
                    VerticalAlignment="Center"
                    Command="{Binding DataContext.OpenMediaCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}" />
          </Grid>
          </Border>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</UserControl>
