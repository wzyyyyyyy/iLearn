<Window
    x:Class="iLearn.Views.Windows.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iLearn.ViewModels"
    x:DataType="vm:ShellViewModel"
    x:CompileBindings="False"
    Width="1580"
    Height="760"
    MinWidth="980"
    MinHeight="640"
    Title="iLearn">
  <Grid ColumnDefinitions="232,*" Background="{StaticResource AppBackgroundBrush}">
    <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="18">
      <DockPanel LastChildFill="True">
        <StackPanel DockPanel.Dock="Top" Margin="0,4,0,24" Spacing="4">
          <TextBlock Text="iLearn"
                     FontSize="30"
                     FontWeight="SemiBold"
                     Foreground="#F8FBFC" />
          <TextBlock Text="学在吉大"
                     FontSize="12"
                     Foreground="#8FA4B1" />
        </StackPanel>

        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Button Command="{Binding DataContext.NavigateCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                      CommandParameter="{Binding}"
                      Margin="0,0,0,8"
                      Classes="nav"
                      Background="{Binding BackgroundBrush}"
                      Foreground="{Binding ForegroundBrush}">
                <Grid ColumnDefinitions="3,*" ColumnSpacing="10">
                  <Border Background="{Binding IndicatorBrush}" CornerRadius="2" />
                  <TextBlock Grid.Column="1"
                             Text="{Binding Title}"
                             FontSize="14"
                             FontWeight="SemiBold"
                             Foreground="{Binding ForegroundBrush}" />
                </Grid>
              </Button>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" RowDefinitions="Auto,*">
      <Border Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrushSoft}"
              BorderThickness="0,0,0,1"
              Padding="30,18">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Spacing="2">
            <TextBlock Text="{Binding CurrentRouteTitle}" Classes="page-title" />
          </StackPanel>
        </Grid>
      </Border>

      <Border Grid.Row="1" Padding="30">
        <ContentControl Name="PageHost" />
      </Border>

      <ItemsControl Grid.Row="1"
                    ItemsSource="{Binding Notifications.Items}"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="28"
                    Width="420"
                    ZIndex="20">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Border Background="{Binding BackgroundBrush}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,13"
                    Margin="0,0,0,10"
                    BoxShadow="0 10 24 0 #1F13202A">
              <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                <Border Background="{Binding AccentBrush}" CornerRadius="2" />
                <StackPanel Grid.Column="1" Spacing="3">
                  <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" />
                  <TextBlock Text="{Binding Message}" Classes="muted" TextWrapping="Wrap" />
                </StackPanel>
              </Grid>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Grid>
  </Grid>
</Window>
